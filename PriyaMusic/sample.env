# ════════════════════════════════════════════════════
#   PriyaMusic — Environment Variables
#   Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════

# ─── Required ────────────────────────────────────────
API_ID=                        # From https://my.telegram.org
API_HASH=                      # From https://my.telegram.org
BOT_TOKEN=                     # From @BotFather
MONGO_DB_URI=                  # From https://cloud.mongodb.com
OWNER_ID=                      # Your Telegram user ID
STRING_SESSION=                # Pyrogram v2 string session (assistant 1)
LOGGER_ID=                     # Log group/channel ID (negative number)

# ─── Optional assistants ─────────────────────────────
STRING_SESSION2=
STRING_SESSION3=
STRING_SESSION4=
STRING_SESSION5=

# ─── Bot identity (customisable by owner) ────────────
BOT_NAME=PriyaMusic            # Display name
BOT_USERNAME=                  # Without @

# ─── Support links ───────────────────────────────────
SUPPORT_CHANNEL=https://t.me/yourchannel
SUPPORT_CHAT=https://t.me/yoursupport

# ─── Heroku deploy ───────────────────────────────────
HEROKU_APP_NAME=
HEROKU_API_KEY=

# ─── Railway / Git ───────────────────────────────────
UPSTREAM_REPO=https://github.com/yourusername/PriyaMusic
UPSTREAM_BRANCH=main
GIT_TOKEN=                     # For private repo

# ─── Spotify ─────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Limits ──────────────────────────────────────────
DURATION_LIMIT=10000           # Max track duration in minutes
PLAYLIST_FETCH_LIMIT=25

# ─── Features ────────────────────────────────────────
AUTO_LEAVING_ASSISTANT=False
AUTOPLAY_ENABLED=True
AUTOPLAY_IDLE_MINUTES=300      # 5 hours idle before autoplay kicks in

# ─── Images (optional — defaults provided) ───────────
START_IMG_URL=
PING_IMG_URL=
PLAYLIST_IMG_URL=
STATS_IMG_URL=
